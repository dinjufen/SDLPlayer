{
  "version": 6,
  "configurePresets": [
    {
      "name": "local-vcpkg",
      "hidden": true,
      "environment": {
        "VSLANG": "1033"
      },
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "<path-to-vcpkg>/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_FEATURE_FLAGS": "manifests"
      }
    },
    {
      "name": "msvc2022-debug-local",
      "inherits": "local-vcpkg",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/msvc2022-debug"
    },
    {
      "name": "msvc2022-release-local",
      "inherits": "local-vcpkg",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/msvc2022-release"
    },
    {
      "name": "msvc2026-debug-local",
      "inherits": "local-vcpkg",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/msvc2026-debug"
    },
    {
      "name": "msvc2026-release-local",
      "inherits": "local-vcpkg",
      "generator": "Visual Studio 18 2026",
      "binaryDir": "${sourceDir}/build/msvc2026-release"
    }
  ],
  "buildPresets": [
    {
      "name": "build-msvc2022-debug-local",
      "configurePreset": "msvc2022-debug-local",
      "configuration": "Debug"
    },
    {
      "name": "build-msvc2022-release-local",
      "configurePreset": "msvc2022-release-local",
      "configuration": "Release"
    },
    {
      "name": "build-msvc2026-debug-local",
      "configurePreset": "msvc2026-debug-local",
      "configuration": "Debug"
    },
    {
      "name": "build-msvc2026-release-local",
      "configurePreset": "msvc2026-release-local",
      "configuration": "Release"
    }
  ]
}
